  {
    "id": "10000000-0000-0000-0000-000000000024",
    "page_id": "f0000000-0000-0000-0000-000000000004",
    "block_type": "faq",
    "order_index": 4,
    "data": {
      "headline_translations": {
        "nl": "Veelgestelde vragen",
        "en": "Frequently asked questions"
      },
      "items": [
        {
          "question_translations": {
            "nl": "Hoeveel personen kunnen er verblijven?",
            "en": "How many guests can stay?"
          },
          "answer_translations": {
            "nl": "De villa biedt comfortabel plek aan 8 personen, verdeeld over 4 ruime slaapkamers.",
            "en": "The villa comfortably hosts up to 8 guests across 4 spacious bedrooms."
          }
        },
        {
          "question_translations": {
            "nl": "Is de villa kindvriendelijk?",
            "en": "Is the villa child-friendly?"
          },
          "answer_translations": {
            "nl": "Ja, het zwembad heeft een veiligheidshek en er zijn kinderbedjes en kinderstoelen beschikbaar op aanvraag.",
            "en": "Yes, the pool has a safety fence and cribs + high chairs are available on request."
          }
        },
        {
          "question_translations": {
            "nl": "Wat is inbegrepen?",
            "en": "What's included?"
          },
          "answer_translations": {
            "nl": "Schoonmaak, beddengoed, handdoeken, wifi en airconditioning zijn inbegrepen. Een privé chef is bij Holiday-tarief inbegrepen.",
            "en": "Cleaning, bedding, towels, wifi, and air conditioning are included. A private chef is included with the Holiday rate."
          }
        }
      ]
    },
    "created_at": "2026-05-10T08:10:00.000Z",
    "updated_at": "2026-05-10T08:10:00.000Z"
  },

