    "block_type": "text",
    "order_index": 1,
    "data": {
      "content_translations": {
        "nl": "Onze villa biedt 4 ruime slaapkamers, een prachtig privézwembad, en uitzicht op de Caribische zee. Ideaal voor families en vriendengroepen die op zoek zijn naar een onvergetelijke vakantie.",
        "en": "Our villa offers 4 spacious bedrooms, a beautiful private pool, and views of the Caribbean Sea. Perfect for families and groups seeking an unforgettable vacation."
      },
      "alignment": "left"
    },
    "created_at": "2026-02-02T10:10:00.000Z",
    "updated_at": "2026-04-15T11:30:00.000Z"
  },
